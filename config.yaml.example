server:
  host: "0.0.0.0"
  port: 5556

model:
  ## Hugging Face Hub path example (uncomment if using Hugging Face Hub) ##
  # path: "Qwen/Qwen2.5-7B-Instruct"

  ## Local path to the model example (uncomment if using local path) ##
  path: "/home/ai-model/LLM/model/Qwen2-5-7B-Instruct" 

  dtype: "bfloat16"
  gpu_memory_utilization: 0.95
  trust_remote_code: true

inference:
  # vLLM API fallback defaults (used when client does not specify)
  default_max_tokens: 1024
  default_temperature: 0.7
  seed : 5555


